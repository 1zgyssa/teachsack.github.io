@echo off
chcp 65001 >nul
echo.
echo ╔══════════════════════════════════════════════════════════════╗
echo ║              🧪 教学工具箱 - 自动更新测试工具               ║
echo ╚══════════════════════════════════════════════════════════════╝
echo.

REM 步骤1: 启动本地更新服务器
echo 🚀 步骤1/3: 启动本地更新服务器...
start "更新服务器" /MIN node update-server.js
echo          ✅ 更新服务器已启动
echo          📍 地址: http://127.0.0.1:3000
echo.

REM 等待服务器启动
echo ⏳ 等待服务器启动...
timeout /t 2 /nobreak >nul
echo.

REM 步骤2: 启动Electron应用（测试模式）
echo 🚀 步骤2/3: 启动教学工具箱（测试模式）...
set UPDATE_TEST_MODE=true
start "教学工具箱" electron .
echo          ✅ 应用已启动
echo          🔧 更新模式: 本地测试
echo.

REM 步骤3: 打开开发者工具查看日志
echo 📝 步骤3/3: 查看更新日志
echo          请按 F12 打开开发者工具，切换到 Console 查看更新日志
echo.
echo ╔══════════════════════════════════════════════════════════════╗
echo ║ 测试流程:                                                    ║
echo ║  1. 应用启动后会自动检查更新                                 ║
echo ║  2. 如果检测到新版本(1.2.0)，会弹出更新提示                  ║
echo ║  3. 点击"立即更新"开始下载                                   ║
echo ║  4. 下载完成后会提示安装                                     ║
echo ║                                                             ║
echo ║ 注意: 测试使用的是模拟安装包，不会真正安装更新                ║
echo ╚══════════════════════════════════════════════════════════════╝
echo.
pause