# TeachSack 统一后端环境变量示例
# 用法：复制本文件为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会入库）
#
# 说明：
#   - 所有变量均为可选；未设置时使用源码中的安全默认值（与旧云版 / 旧 server.js 保持一致）。
#   - 生产环境强烈建议通过环境变量覆盖 ADMIN_PASSWORD 与 SECRET_KEY，
#     避免密钥进入版本库（遵循 12-factor 配置规范）。

# 管理员后台登录密码（默认 070515，保持与旧版本一致）
ADMIN_PASSWORD=070515

# 授权码签名密钥（默认内置值，建议替换为自定义强密钥）
SECRET_KEY=T3@chS@ck!2024#K3y

# Cloudflare KV（反馈 / 支付存储）；留空则自动回退到本地 data/ 文件，便于本地开发
CF_API_TOKEN=
CF_ACCOUNT_ID=
KV_NAMESPACE_ID=8e93d84339c74c57957b7f2423bd81de

# 服务端口
PORT=3000
